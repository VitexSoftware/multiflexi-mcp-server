# Example environment variables for MultiFlexi MCP Server

# Required: MultiFlexi API host URL
MULTIFLEXI_HOST=https://your-multiflexi-instance.com

# Optional: Authentication credentials
MULTIFLEXI_USERNAME=your-username
MULTIFLEXI_PASSWORD=your-password

# Optional: SSL verification (default: true)
MULTIFLEXI_VERIFY_SSL=true

# Optional: Request timeout in seconds (default: 30)
MULTIFLEXI_TIMEOUT=30

# Optional: Maximum number of retries (default: 3)
MULTIFLEXI_MAX_RETRIES=3

# Optional: Enable debug logging (default: false)
MULTIFLEXI_DEBUG=false